# ===== x-content-mvp configuration =====
# Copy this file to .env and fill in your own values.
# Never commit your real .env or real API keys.

# OpenAI (or OpenAI-compatible) API key. Leave empty to run in
# heuristic fallback mode (no AI calls).
OPENAI_API_KEY=YOUR_KEY_HERE

# Optional: override the API base URL for an OpenAI-compatible gateway.
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: model id and request timeout.
AI_MODEL=gpt-4.1-mini
AI_TIMEOUT_SECONDS=90

# Optional: server binding.
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# Optional: comma-separated CORS origins (defaults to localhost only).
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
