# ===== youtube-creator configuration =====
# Copy this file to .env and fill in your own values.
# Never commit your real .env or real API keys.

# Anthropic API key and model id (required to run the agent).
ANTHROPIC_API_KEY=YOUR_KEY_HERE
MODEL_ID=claude-opus-4-5

# Optional: override the Anthropic base URL for a compatible gateway.
# When ANTHROPIC_BASE_URL is set, ANTHROPIC_AUTH_TOKEN is cleared automatically.
# ANTHROPIC_BASE_URL=

# YouTube Data API v3 OAuth credentials (required only when uploading).
# Get them from https://console.cloud.google.com (OAuth 2.0 Client ID, desktop app).
YOUTUBE_CLIENT_ID=YOUR_CLIENT_ID_HERE
YOUTUBE_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE

# Optional: extra PATH entries (colon-separated) so the agent can find
# edge-tts / ffmpeg if they live outside the default PATH.
# Example: PATH_EXTRA=/opt/homebrew/bin:/usr/local/bin
# PATH_EXTRA=
